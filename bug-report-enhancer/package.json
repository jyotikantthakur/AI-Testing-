{
  "name": "bug-report-app",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:electron": "npm run build && node scripts/copy-standalone.js && electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "groq-sdk": "^0.37.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.bugreportenhancer.app",
    "productName": "Bug Report Enhancer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      ".next/standalone/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    }
  }
}